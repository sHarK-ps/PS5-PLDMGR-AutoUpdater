<opml version="2.0">
  <head>
    <title>PS5 HEN &amp; Loaders</title>
  </head>
  <body>
    <outline title="PS5 HEN Loader">
      <outline title="etaHEN" xmlUrl="https://github.com/etaHEN/etaHEN" author="LightningMods" description="Le Homebrew Enabler (HEN) de référence pour la PS5 avec serveurs de triche, plugins et gestionnaire de mémoire intégrés." />
      <outline title="PS5 Unified Autoloader" xmlUrl="https://github.com/itsPLK/ps5-unified-autoloader" author="itsPLK" description="Chargeur universel de payloads permettant de lancer automatiquement vos outils favoris au démarrage de l'exploit." />
      <outline title="PS5 Payload Manager" xmlUrl="https://github.com/itsPLK/ps5-payload-manager" author="itsPLK" description="Interface d'administration et de gestion réseau pour envoyer, activer et ordonner vos fichiers ELF/BIN sur la console." />
      <outline title="ELF Arsenal" xmlUrl="https://git.etawen.dev/soniciso/elf-arsenal" author="SonicIso" description="Boîte à outils regroupant une collection complète de payloads utilitaires pour les consoles jailbreakées." />
    </outline>
  </body>
